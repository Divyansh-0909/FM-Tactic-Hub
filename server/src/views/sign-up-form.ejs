<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Sign Up</title>
  <link rel="stylesheet" href="/sign-up-form.css">
</head>
<body>
  <div class="account-form">
    <h1>
      CREATE ACCOUNT
    </h1>
    <p>
      Join FM Tactic Hub today.
    </p>
    <form action="/sign-up" method="POST">
      <fieldset>
        <label for="username">USERNAME</label>
        <input id="username" name="username" type="text" placeholder="xyz123"/>
      </fieldset>
      <fieldset>
        <label for="email">EMAIL</label>
        <input id="email" name="email" type="email" placeholder="xyz@example.com"/>
      </fieldset>
      <fieldset>
        <!-- add show password feature -->
        <label for="password">PASSWORD</label>
        <input id="password" name="password" type="password" placeholder="••••••••••"/>
      </fieldset>
      <fieldset>
        <label for="password">CONFIRM PASSWORD</label>
        <input id="password" name="password" type="password" placeholder="••••••••••"/>
      </fieldset>
      <% if (error) { %>
          <div class="error-message">
            <img src="/alert-rhombus.svg" alt="alert">
            <p><%= error %></p>
          </div>
        <% } %>
      <fieldset class="buttons">
        <div class="access-buttons">
          <a href="/log-in">Log in</a>
          <button type="submit">Sign up</button>
        </div>
        <a href="/login/google" class="sign-in-google"><img src="/Google__G__logo.svg.webp" alt="google-logo">Sign up with Google</a>
      </fieldset>
     </form>
  </div>
</body>
</html>

